{
  "name": "詐欺電話撃退アプリ",
  "short_name": "詐欺撃退",
  "description": "通話をその場で録音・文字起こしし、詐欺のサインを検知して警告します",
  "start_url": "./",
  "scope": "./",
  "display": "standalone",
  "orientation": "portrait",
  "background_color": "#7a1f1f",
  "theme_color": "#7a1f1f",
  "icons": [
    { "src": "icon-192.png", "sizes": "192x192", "type": "image/png", "purpose": "any" },
    { "src": "icon-512.png", "sizes": "512x512", "type": "image/png", "purpose": "any" }
  ],
  "share_target": {
    "action": "./share-target/",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "files": [
        { "name": "file", "accept": ["audio/*", "video/mp4", "video/webm"] }
      ]
    }
  }
}
